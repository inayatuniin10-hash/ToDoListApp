<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FEF7F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header Tanggal -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hari ini"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#D4A5A5"
            android:layout_marginBottom="12dp"/>

        <!-- Kalender Mini -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="20dp"
            android:backgroundTint="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="April 2026"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#D4A5A5"
                    android:layout_marginBottom="12dp"/>

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="7"
                    android:rowCount="6">

                    <!-- Hari dalam seminggu -->
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="Min" android:gravity="center" android:textSize="12sp" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="Sen" android:gravity="center" android:textSize="12sp" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="Sel" android:gravity="center" android:textSize="12sp" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="Rab" android:gravity="center" android:textSize="12sp" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="Kam" android:gravity="center" android:textSize="12sp" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="Jum" android:gravity="center" android:textSize="12sp" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="Sab" android:gravity="center" android:textSize="12sp" android:textColor="#8B6B6B"/>

                    <!-- Tanggal (contoh untuk April 2026) -->
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="" android:gravity="center"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="" android:gravity="center"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="1" android:gravity="center" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="2" android:gravity="center" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="3" android:gravity="center" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="4" android:gravity="center" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="5" android:gravity="center" android:textColor="#8B6B6B"/>

                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="6" android:gravity="center" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="7" android:gravity="center" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="8" android:gravity="center" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="9" android:gravity="center" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="10" android:gravity="center" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="11" android:gravity="center" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="12" android:gravity="center" android:textColor="#8B6B6B"/>

                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="13" android:gravity="center" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="14" android:gravity="center" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="15" android:gravity="center" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="16" android:gravity="center" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="17" android:gravity="center" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="18" android:gravity="center" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="19" android:gravity="center" android:textColor="#8B6B6B"/>

                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="20" android:gravity="center" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="21" android:gravity="center" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="22" android:gravity="center" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="23" android:gravity="center" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="24" android:gravity="center" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="25" android:gravity="center" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="26" android:gravity="center" android:background="#E8D5D5" android:backgroundTint="#E8D5D5" android:textColor="#D4A5A5" android:textStyle="bold"/>

                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="27" android:gravity="center" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="28" android:gravity="center" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="29" android:gravity="center" android:textColor="#8B6B6B"/>
                    <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="30" android:gravity="center" android:textColor="#8B6B6B"/>
                </GridLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Quote Motivasi (Pengganti Diskon) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="24dp"
            android:backgroundTint="#E8D5D5">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✨"
                    android:textSize="32sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rawat versi terbaik dari dirimu."
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#8B6B6B"
                    android:gravity="center"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Setiap hari adalah kesempatan baru untuk berkembang"
                    android:textSize="12sp"
                    android:textColor="#D4A5A5"
                    android:gravity="center"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Mood Question -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bagaimana perasaanmu hari ini?"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#8B6B6B"
            android:layout_marginBottom="16dp"/>

        <!-- Emoji Mood -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:text="😊"
                    android:textSize="32sp"
                    android:gravity="center"
                    android:background="@drawable/mood_bg"
                    android:padding="12dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Baik" android:textSize="12sp" android:textColor="#8B6B6B" android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:text="😐"
                    android:textSize="32sp"
                    android:gravity="center"
                    android:background="@drawable/mood_bg"
                    android:padding="12dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Biasa" android:textSize="12sp" android:textColor="#8B6B6B" android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:text="😔"
                    android:textSize="32sp"
                    android:gravity="center"
                    android:background="@drawable/mood_bg"
                    android:padding="12dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sedih" android:textSize="12sp" android:textColor="#8B6B6B" android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:text="😡"
                    android:textSize="32sp"
                    android:gravity="center"
                    android:background="@drawable/mood_bg"
                    android:padding="12dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Marah" android:textSize="12sp" android:textColor="#8B6B6B" android:layout_marginTop="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Tambah Refleksi Button -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="+ Tambah refleksi"
                    android:textSize="16sp"
                    android:textColor="#D4A5A5"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Harian • Kapan pun"
                    android:textSize="12sp"
                    android:textColor="#8B6B6B"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Statistik Harian -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#D4A5A5"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tugas Selesai"
                        android:textSize="12sp"
                        android:textColor="#8B6B6B"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#D4A5A5"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tersisa"
                        android:textSize="12sp"
                        android:textColor="#8B6B6B"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="100%"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#D4A5A5"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Produktivitas"
                        android:textSize="12sp"
                        android:textColor="#8B6B6B"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Judul Refleksi -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Refleksi Hari Ini"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#8B6B6B"
            android:layout_marginBottom="12dp"/>

        <!-- Daftar Refleksi -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewReflections"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>
</ScrollView>