<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FEF7F0"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mengorganisir Harimu"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#D4A5A5"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Daftar tugas"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#8B6B6B"
        android:layout_marginBottom="12dp"/>

    <!-- Category Tabs -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView android:layout_width="wrap_content" android:layout_height="40dp" android:text="Semua" android:paddingStart="16dp" android:paddingEnd="16dp" android:gravity="center" android:background="@drawable/category_selected" android:textColor="#D4A5A5" android:layout_marginEnd="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="40dp" android:text="Kerja" android:paddingStart="16dp" android:paddingEnd="16dp" android:gravity="center" android:background="@drawable/category_bg" android:textColor="#8B6B6B" android:layout_marginEnd="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="40dp" android:text="Pribadi" android:paddingStart="16dp" android:paddingEnd="16dp" android:gravity="center" android:background="@drawable/category_bg" android:textColor="#8B6B6B" android:layout_marginEnd="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="40dp" android:text="Sasaran" android:paddingStart="16dp" android:paddingEnd="16dp" android:gravity="center" android:background="@drawable/category_bg" android:textColor="#8B6B6B"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Tersisa Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tersisa"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#8B6B6B"
        android:layout_marginBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewTasks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
</LinearLayout>